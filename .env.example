# --- Быстрый старт (корень репозитория) ---
# Не программист? Откройте в проекте файл: НАЧАЛО-БЕЗ-КОДА.md
# npm run go                → сайт у себя; в терминале смотрите строку Local: (5173 или 5174, если 5173 занят)
# npm run zip:dist          → архив site-dist-for-upload.zip для загрузки на хостинг
# npm run env:init          → создать .env из этого файла (если .env ещё нет)
# npm run env:secret        → случайный JWT_SECRET в терминал → вставить в .env
# npm run env:check -- --production  → проверка перед продом
# npm run prod:check                 → то же + СДЭК / Точка / Telegram / почта / БД
# На VPS через GitHub Actions задавайте JWT_SECRET и DATABASE_URL в Secrets репозитория

# Frontend
VITE_API_BASE_URL=http://localhost:8787/api
# Опционально: ключ JS API Яндекс.Карт (корзина СДЭК). Без него используется встроенный ключ по умолчанию.
VITE_YANDEX_MAPS_API_KEY=
# Опционально: только если админка Telegram (poll/broadcast/webhook setup) ещё на Supabase Edge — полный URL без хвоста /
# VITE_TELEGRAM_EDGE_BASE_URL=https://xxxx.supabase.co/functions/v1/make-server-aa167a09
VITE_TELEGRAM_EDGE_BASE_URL=
# Ключ anon для запросов к Edge выше (если нужен)
VITE_TELEGRAM_EDGE_ANON_KEY=

# Server
PORT=8787
NODE_ENV=development
ALLOWED_ORIGIN=http://localhost:5173
# Production: comma-separated browser origins (use when API is on api. subdomain)
# ALLOWED_ORIGINS=https://coffeenechai.ru,https://www.coffeenechai.ru
FRONTEND_BASE_URL=http://localhost:5173
# Секрет подписи JWT для розницы (вход email/пароль). Обязателен в проде.
JWT_SECRET=
# Публичный URL самого API (без /api). Нужен, если FRONTEND_BASE_URL — другой домен: иначе ссылки на /api/uploads/… строятся из Host запроса (за nginx с X-Forwarded-Proto / Host).
# Пример: PUBLIC_API_BASE_URL=https://api.coffeenechai.ru
PUBLIC_API_BASE_URL=

# Database (for full Supabase migration)
DATABASE_URL=postgres://user:password@localhost:5432/site_db

# CDEK (API 2.0, боевой https://api.cdek.ru/v2)
# В lk.cdek.ru: раздел про интеграцию/API — «Идентификатор» (Account) и «Секретный ключ» (Secure password).
# Не подставляйте логин договора и пароль от входа в сайт СДЭК. Одна строка на переменную, без кавычек и без пробела в конце.
CDEK_ACCOUNT=
CDEK_SECRET=

# Telegram (уведомления о заказах и заявках; не коммитьте реальные значения)
# Обход ETIMEDOUT до api.telegram.org: задеплойте Edge Function supabase/functions/telegram-relay (см. relay ниже),
# на VPS задайте TELEGRAM_RELAY_URL + TELEGRAM_RELAY_SECRET — тогда TELEGRAM_BOT_TOKEN на VPS не нужен для отправки.
# На VPS: вручную в .env или GitHub → Repository secrets (workflow deploy-reg-vps допишет в .env при деплое):
#   TELEGRAM_BOT_TOKEN, TELEGRAM_CHAT_ID, TELEGRAM_HTTPS_PROXY, HTTPS_PROXY, TELEGRAM_RELAY_URL, TELEGRAM_RELAY_SECRET
#   CDEK_ACCOUNT, CDEK_SECRET
#   TOCHKA_JWT_TOKEN, TOCHKA_CUSTOMER_CODE, TOCHKA_INVOICE_ACCOUNT_ID, TOCHKA_MERCHANT_ID, TOCHKA_TERMINAL_ID, TOCHKA_CLIENT_ID
TELEGRAM_BOT_TOKEN=
# ID канала/чата: для общей ленты заявок — id приватного канала (часто -100…), бот должен быть админом канала
TELEGRAM_CHAT_ID=
# Если VPS не достучится до api.telegram.org (ETIMEDOUT): выходной прокси, чаще http://user:pass@host:port
TELEGRAM_HTTPS_PROXY=
# или стандартная переменная для любого исходящего HTTPS-прокси
HTTPS_PROXY=
# Relay через Supabase Edge (полный URL, например https://xxxx.supabase.co/functions/v1/telegram-relay)
TELEGRAM_RELAY_URL=
# Общий секрет с Supabase Edge Secrets TELEGRAM_RELAY_SECRET (случайная длинная строка)
TELEGRAM_RELAY_SECRET=
# Еженедельный бэкап БД на почту (GitHub Actions → Weekly database email backup + WEEKLY_EMAIL_BACKUP_ENABLED=1)
# Кнопка в админке «отправить бэкап» вызывает POST /api/backup/send-email → тот же сценарий, что node server/scripts/weekly-email-backup.mjs
# Без DATABASE_URL бэкапится server/data/db.json. Mail.ru: smtp.mail.ru, порт 465, пароль приложения.
BACKUP_EMAIL_TO=dakolosovs@mail.ru
BACKUP_SMTP_HOST=
BACKUP_SMTP_PORT=465
BACKUP_SMTP_SECURE=true
BACKUP_SMTP_USER=
BACKUP_SMTP_PASS=

# Tochka
TOCHKA_JWT_TOKEN=
# Опционально: счёт выставляется с этого р/с (bills API); если пусто — значение как в старом Supabase
TOCHKA_INVOICE_ACCOUNT_ID=
TOCHKA_CUSTOMER_CODE=
TOCHKA_MERCHANT_ID=
TOCHKA_TERMINAL_ID=
TOCHKA_CLIENT_ID=
